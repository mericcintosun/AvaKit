# Never ship Foundry build artifacts inside templates — only the contract
# sources (contracts/src) and foundry.toml belong in a scaffolded app. These
# dirs are regenerated by `forge build`; the root .gitignore skips them for git,
# but npm's `files` allowlist ("templates") would otherwise pack them, so they
# must be excluded here too.
templates/**/contracts/out
templates/**/contracts/cache
templates/**/contracts/broadcast
