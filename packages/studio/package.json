{
  "name": "@avakit/studio",
  "version": "0.1.0",
  "description": "AvaKit Studio — a local control center for Avalanche development (L1s, ICM, devnets).",
  "license": "MIT",
  "type": "module",
  "bin": {
    "avakit-studio": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup && vite build",
    "build:server": "tsup",
    "build:ui": "vite build",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit && tsc -p ui/tsconfig.json --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@avakit/core": "workspace:*",
    "clsx": "2.1.1",
    "lucide-react": "1.22.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwind-merge": "3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.3.2",
    "@types/node": "catalog:",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^5.0.0",
    "tailwindcss": "4.3.2",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vite": "^7.0.0",
    "vitest": "catalog:"
  },
  "keywords": ["avalanche", "avax", "studio", "dashboard", "l1", "subnet", "icm", "devnet", "avakit"],
  "author": "AvaKit contributors",
  "homepage": "https://github.com/mericcintosun/AvaKit#readme",
  "bugs": { "url": "https://github.com/mericcintosun/AvaKit/issues" },
  "repository": { "type": "git", "url": "git+https://github.com/mericcintosun/AvaKit.git", "directory": "packages/studio" },
  "engines": { "node": ">=20.11" }
}
